# ==== Configuración de la App de Boda ====
# Copia este archivo como .env y rellena tus valores.

# Código de acceso que los invitados escribirán para entrar
ACCESS_CODE=CODIGO-INVITADOS

# Códigos de los novios (superusuarios): pueden eliminar cualquier foto o vídeo.
# Separados por comas.
ADMIN_CODES=CODIGO-NOVIO1,CODIGO-NOVIA2

# Puerto del servidor
PORT=3000

# Título del evento y nombres de la pareja (se muestran en la app)
EVENT_TITLE=Nuestra Boda
COUPLE_NAMES=Los Novios
EVENT_DATE=

# Tamaño máximo por archivo subido (en MB)
MAX_UPLOAD_MB=600

# Capacidad total de almacenamiento (en GB). El límite real también depende del disco.
MAX_STORAGE_GB=30

# URL pública de la app (para el QR). Déjalo vacío en local y se autodetecta.
PUBLIC_URL=
